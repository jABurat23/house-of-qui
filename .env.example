# ──────────────────────────────────────────────────────
# 🏛️  HOUSE OF QUI — Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ──────────────────────────────────────────────────────

# 🔐 Imperial JWT Secret (use a strong random string)
IMPERIAL_SECRET=change-me-to-a-strong-random-secret

# 🗃️  Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=house_of_qui

# 🌐 API Configuration
API_PORT=4000
DASHBOARD_PORT=5173
